{
	"parser": "babel-eslint",
	"parserOptions": {
		"ecmaVersion": 2018,
    "sourceType": "module"
	},
	"env": {
		"browser": true,
    "amd": true,
    "node": true
	},
	"plugins": [
		"react",
		"import"
	],
	"extends": [
		"eslint:recommended",
		"plugin:react/recommended"
	],
	"rules": {
		"comma-dangle": 0,
		// "no-undef": "off",
		"indent": [
			"error",
			"tab"
		]
	}
}